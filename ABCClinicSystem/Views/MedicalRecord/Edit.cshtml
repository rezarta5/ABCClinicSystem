@model ABCClinicSystem.Models.MedicalRecord
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Edit Medical Record";
}

<h2>Edit Medical Record</h2>

<!-- Success message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <!-- Patient Dropdown -->
    <div class="mb-3">
        <label asp-for="PatientId" class="form-label">Patient</label>
        <select asp-for="PatientId" class="form-select" asp-items="ViewBag.Patients" required>
            <option value="">-- Select Patient --</option>
        </select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <!-- Doctor -->
    @if (User.IsInRole("Doctor"))
    {
        <input asp-for="DoctorId" type="hidden" 
               value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />
    }
    else
    {
        <div class="mb-3">
            <label asp-for="DoctorId" class="form-label">Doctor</label>
            <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.Doctors">
                <option value="">-- Select Doctor --</option>
            </select>
            <span asp-validation-for="DoctorId" class="text-danger"></span>
        </div>
    }

    <!-- Diagnosis -->
    <div class="mb-3">
        <label asp-for="Diagnosis" class="form-label">Diagnosis</label>
        <input asp-for="Diagnosis" class="form-control" maxlength="500" />
        <span asp-validation-for="Diagnosis" class="text-danger"></span>
    </div>

    <!-- Notes -->
    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notes / Observations</label>
        <textarea asp-for="Notes" class="form-control" rows="3" maxlength="2000"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <!-- Record Date & Time (UTC) -->
    <div class="mb-3">
        <label asp-for="CreatedAt" class="form-label">Record Date & Time (UTC)</label>
        <input asp-for="CreatedAt" type="datetime-local" class="form-control" 
               value="@(Model?.CreatedAt.ToString("yyyy-MM-ddTHH:mm") ?? DateTime.UtcNow.ToString("yyyy-MM-ddTHH:mm"))" />
        <span asp-validation-for="CreatedAt" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update Record</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}