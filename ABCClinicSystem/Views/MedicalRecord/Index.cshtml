@model IEnumerable<ABCClinicSystem.Models.MedicalRecord>

@{
    ViewData["Title"] = "Medical Records";
}

<h2 class="mb-3">Medical Records</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p class="mb-3">
    <a class="btn btn-primary" asp-action="Create">Add Record</a>
</p>

<div class="table-responsive">
    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Diagnosis</th>
                <th>Notes</th>
                <th>Date & Time</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Patient?.FullName</td>
                        <td>@r.Doctor?.FullName</td>
                        <td>@r.Diagnosis</td>
                        <td>@r.Notes</td>
                        <td>@r.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-warning btn-sm me-1">Edit</a>
                            <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No medical records found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>