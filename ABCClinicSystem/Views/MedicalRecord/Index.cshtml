@model IEnumerable<ABCClinicSystem.Models.MedicalRecord>

@{
    ViewData["Title"] = "Medical Records";
}

<h2 class="mb-3">Medical Records</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
{
    <p class="mb-3">
        <a class="btn btn-primary" asp-action="Create">Add Record</a>
    </p>
}

<div class="table-responsive">
    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Diagnosis</th>
                <th>Notes</th>
                <th>Date & Time</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Patient?.FullName</td>
                        <td>@r.Doctor?.FullName</td>
                        <td>@r.Diagnosis</td>
                        <td>@r.Notes</td>
                        <td>@r.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td>

                            @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-1">

                                    <a asp-action="Edit"
                                       asp-route-id="@r.Id"
                                       class="btn btn-outline-warning btn-sm">
                                        Edit
                                    </a>

                                    <form asp-action="Delete"
                                          asp-route-id="@r.Id"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this record?');">
                                            Delete
                                        </button>
                                    </form>

                                </div>
                            }

                            @* PATIENT ONLY SEES LABEL (NO DATA REMOVED) *@
                            else if (User.IsInRole("Patient"))
                            {
                                <span class="badge bg-info text-dark">
                                    Read Only
                                </span>
                            }

                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No medical records found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>