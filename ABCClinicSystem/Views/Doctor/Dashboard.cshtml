@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="container py-5">

    <!--  Header -->
    <div class="card mb-5 shadow-sm border-0">
        <div class="card-body bg-light rounded-3 p-4 d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h1 class="display-5 fw-bold text-primary mb-2">Doctor Dashboard</h1>
                <p class="lead mb-0">Welcome, <strong>@ViewBag.FullName</strong></p>
            </div>
            <div class="text-end">
                <p class="mb-0 text-muted">
                    <i class="bi bi-calendar3 me-1"></i>
                    @DateTime.Now.ToString("dddd, MMMM dd yyyy")
                </p>
            </div>
        </div>
    </div>

  
    
    
    <!-- Summary Cards -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-5 g-4 mb-5">
        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-primary">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-primary fw-bold mb-2">Total Appointments</h6>
                        <p class="display-6 mb-0">@((ViewBag.TotalAppointments ?? 0))</p>
                    </div>
                    <i class="bi bi-calendar2-check display-4 text-primary"></i>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-success">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-success fw-bold text-uppercase mb-2">Upcoming Appointments</h6>
                        <p class="display-6 mb-0">@((ViewBag.UpcomingAppointments?.Count ?? 0))</p>
                    </div>
                    <i class="bi bi-clock display-4 text-success"></i>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-info">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-info fw-bold text-uppercase mb-2">Today's Appointments</h6>
                        <p class="display-6 mb-0">@((ViewBag.TodaysAppointments?.Count ?? 0))</p>
                    </div>
                    <i class="bi bi-calendar-day display-4 text-info"></i>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-warning">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-warning fw-bold text-uppercase mb-2">Recent Records</h6>
                        <p class="display-6 mb-0">@((ViewBag.RecentMedicalRecords?.Count ?? 0))</p>
                    </div>
                    <i class="bi bi-journal-medical display-4 text-warning"></i>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-dark">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-dark fw-bold mb-2">Total Revenue</h6>
                        <p class="display-6 mb-0">$@((ViewBag.TotalRevenue ?? 0).ToString("F2"))</p>
                    </div>
                    <i class="bi bi-currency-dollar display-4 text-dark"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row g-4 mb-5">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100 p-3">
                <h6 class="fw-bold text-primary mb-3">Appointments Trend (This Month)</h6>
                <canvas id="appointmentsChart"></canvas>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm h-100 p-3">
                <h6 class="fw-bold text-success mb-3">Revenue Trend (This Year)</h6>
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Quick Access Buttons (Pill Style) -->
    <div class="card shadow-sm border-0 rounded-4 p-3 mb-5">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0 text-dark">Quick Access</h6>
            
        </div>

        <div class="d-flex flex-wrap gap-2">

            <a asp-controller="Appointment" asp-action="Index"
               class="text-decoration-none px-3 py-2 rounded-pill pill-btn pill-blue">

                <i class="bi bi-calendar-check me-1"></i> Appointments
            </a>

            <a asp-controller="MedicalRecord" asp-action="Index"
               class="text-decoration-none px-3 py-2 rounded-pill pill-btn pill-green">

                <i class="bi bi-journal-medical me-1"></i> Records
            </a>

            <a asp-controller="Doctor" asp-action="AllBills"
               class="text-decoration-none px-3 py-2 rounded-pill pill-btn pill-orange">

                <i class="bi bi-receipt me-1"></i> Bills
            </a>

        </div>
    </div>

    <style>
    .pill-btn {
        font-size: 13px;
        font-weight: 600;
        border: 1px solid transparent;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
    }

    .pill-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px rgba(0,0,0,0.15);
    }

    .pill-blue {
        background: #e8f1ff;
        color: #0d6efd;
        border-color: #cfe2ff;
    }

    .pill-blue:hover {
        background: #0d6efd;
        color: #fff;
    }

    .pill-green {
        background: #e7f9f0;
        color: #198754;
        border-color: #bff0d7;
    }

    .pill-green:hover {
        background: #198754;
        color: #fff;
    }

    .pill-orange {
        background: #fff3e6;
        color: #fd7e14;
        border-color: #ffe0b2;
    }

    .pill-orange:hover {
        background: #fd7e14;
        color: #fff;
    }
</style>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const appointmentLabels = @Html.Raw(Json.Serialize(ViewBag.AppointmentsDays));
        const appointmentData = @Html.Raw(Json.Serialize(ViewBag.AppointmentsCount));
        const revenueLabels = @Html.Raw(Json.Serialize(ViewBag.RevenueMonths));
        const revenueData = @Html.Raw(Json.Serialize(ViewBag.RevenueValues));

        new Chart(document.getElementById('appointmentsChart'), {
            type: 'line',
            data: { labels: appointmentLabels, datasets: [{ label: 'Appointments', data: appointmentData, tension: 0.3 }] }
        });

        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: { labels: revenueLabels, datasets: [{ label: 'Revenue ($)', data: revenueData }] }
        });

        // Auto-hide success message
        setTimeout(() => {
            const el = document.getElementById('successMessage');
            if (el) { el.style.opacity = '0'; setTimeout(() => el.remove(), 500); }
        }, 3000);
    </script>
}
    