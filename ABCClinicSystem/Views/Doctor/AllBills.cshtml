@model IEnumerable<ABCClinicSystem.Models.Bill>
@{
    ViewData["Title"] = "All Bills";
    
}
@if (TempData["Success"] != null)
{
    <div id="successMessage" class="alert alert-success">
        @TempData["Success"]
    </div>
}

<h2 class="mb-4 text-primary">All Bills</h2>

<!-- Display success/error messages -->
<script>
    // Hide messages after 3 seconds
    setTimeout(function() {
        var success = document.getElementById('successMessage');
        if(success) {
            success.style.transition = "opacity 0.5s";
            success.style.opacity = "0";
            setTimeout(() => success.remove(), 500);
        }

        var error = document.getElementById('errorMessage');
        if(error) {
            error.style.transition = "opacity 0.5s";
            error.style.opacity = "0";
            setTimeout(() => error.remove(), 500);
        }
    }, 3000);
</script>

<!-- Add Bill Button -->
<div class="mb-3">
    <a asp-controller="Doctor" asp-action="CreateBill" class="btn btn-success">Add New Bill</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Amount ($)</th>
            <th>Due Date</th>
            <th>Paid</th>
            <th>Status</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var bill in Model)
    {
        <tr>
            <td>@(bill.Patient?.FullName ?? "N/A")</td>
            <td>@(bill.Doctor?.FullName ?? "N/A")</td>
            <td>@bill.Amount.ToString("F2")</td>
            <td>@bill.DueDate?.ToString("dd MMM yyyy")</td>
            
            <!-- Paid Column -->
            <td>
                @if (bill.Status == "Paid")
                {
                    <span class="badge bg-success">Yes</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">No</span>
                }
            </td>

            <!-- Status Badge -->
            <td>
                @{
                    string badgeClass;
                    if (bill.Status == "Pending")
                    {
                        badgeClass = "bg-warning text-dark";
                    }
                    else if (bill.Status == "Paid")
                    {
                        badgeClass = "bg-success text-white";
                    }
                    else if (bill.Status == "Cancelled")
                    {
                        badgeClass = "bg-danger text-white";
                    }
                    else
                    {
                        badgeClass = "bg-secondary text-white";
                    }
                }
                <span class="badge @badgeClass">@bill.Status</span>
            </td>

            <td>@bill.Description</td>
            

            <!-- Actions -->
            <td>
                
                <!-- Update Bill Status Form -->
                <form asp-controller="Doctor" asp-action="UpdateBillStatus" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@bill.Id"/>
                    <select name="status" class="form-select form-select-sm d-inline w-auto">

                        @if (bill.Status == "Pending")
                        {
                            <option value="Pending" selected>Pending</option>
                        }
                        else
                        {
                            <option value="Pending">Pending</option>
                        }

                        @if (bill.Status == "Paid")
                        {
                            <option value="Paid" selected>Paid</option>
                        }
                        else
                        {
                            <option value="Paid">Paid</option>
                        }

                        @if (bill.Status == "Cancelled")
                        {
                            <option value="Cancelled" selected>Cancelled</option>
                        }
                        else
                        {
                            <option value="Cancelled">Cancelled</option>
                        }

                    </select>
                    <button type="submit" class="btn btn-sm btn-primary ms-1">Update</button>
                </form>
                
                

                <!-- Delete Bill Form -->
                <form asp-controller="Doctor" asp-action="DeleteBill" method="post" class="d-inline ms-1"
                      onsubmit="return confirm('Are you sure you want to delete this bill?');">
                    <input type="hidden" name="id" value="@bill.Id"/>
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>

                <!-- Edit Button -->
                <a asp-controller="Doctor" asp-action="EditBill" asp-route-id="@bill.Id" class="btn btn-sm btn-warning ms-1">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>