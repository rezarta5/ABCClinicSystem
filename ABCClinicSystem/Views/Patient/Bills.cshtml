@model IEnumerable<ABCClinicSystem.Models.Bill>

@{
    ViewData["Title"] = "My Bills";
}

@Html.AntiForgeryToken()

<div class="container py-4">

    <!-- Alert -->
    <div id="paymentAlert"
         class="alert alert-success alert-dismissible fade show shadow-sm d-none"
         role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        Payment successful!
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold mb-0">My Bills</h2>
    </div>

    <!-- Summary -->
    <div class="d-flex gap-3 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-body py-2 px-3">
                <div class="text-success fw-bold">
                    Paid: @Model.Count(x => x.Status == "Paid")
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body py-2 px-3">
                <div class="text-warning fw-bold">
                    Pending: @Model.Count(x => x.Status == "Pending")
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            You currently have no bills.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-dark">
                            <tr>
                                <th>Doctor</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Due Date</th>
                                <th>Created</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                        @foreach (var bill in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@bill.Doctor?.FullName</td>
                                <td>@bill.Description</td>
                                <td class="fw-bold text-primary">@bill.Amount.ToString("C")</td>

                                <td>
                                    @if (bill.Status == "Paid")
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else if (bill.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@bill.Status</span>
                                    }
                                </td>

                                <td>@bill.DueDate?.ToString("dd MMM yyyy")</td>
                                <td class="text-muted">@bill.CreatedAt.ToString("dd MMM yyyy")</td>

                                <td>
                                    @if (User.IsInRole("Patient") && bill.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-primary pay-btn"
                                                data-id="@bill.Id">
                                            Pay Bill
                                        </button>
                                    }
                                    else if (bill.Status == "Paid")
                                    {
                                        <span class="text-success fw-bold">✔ Paid</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    }
</div>

<!-- MODAL -->
<div class="modal fade" id="payModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to pay this bill?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" id="confirmPayBtn" class="btn btn-primary">
                    Yes, Pay
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedBillId = 0;
    let payModal = new bootstrap.Modal(document.getElementById('payModal'));

    // open modal
    $(document).on("click", ".pay-btn", function () {
        selectedBillId = $(this).data("id");
        payModal.show();
    });

    // confirm payment
    $("#confirmPayBtn").click(function () {

        $.ajax({
            url: '@Url.Action("PayBill", "Patient")',
            type: "POST",
            data: { id: selectedBillId },
            headers: {
                "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
            },

            success: function () {

                payModal.hide();

                $("#paymentAlert")
                    .removeClass("d-none alert-danger")
                    .addClass("alert-success")
                    .text("Payment successful!")
                    .fadeIn();

                setTimeout(() => location.reload(), 1200);
            },

            error: function () {

                payModal.hide();

                $("#paymentAlert")
                    .removeClass("d-none alert-success")
                    .addClass("alert-danger")
                    .text("Payment failed!")
                    .fadeIn();
            }
        });

    });
</script>
}