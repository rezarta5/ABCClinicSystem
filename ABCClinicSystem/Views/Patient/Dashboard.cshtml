@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-light rounded-4 shadow-sm">

        <div>
            <h1 class="display-6 fw-bold text-primary mb-1">
                Patient Dashboard
            </h1>
            <p class="text-muted fs-5 mb-0">
                Welcome, <strong class="text-dark">@ViewBag.FullName</strong>
            </p>
        </div>

    </div>

    <!-- Cards -->
    <div class="row g-4 mb-5">

        <!-- Appointments -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-primary-soft text-primary mb-3">
                        <i class="bi bi-calendar2-check fs-2"></i>
                    </div>
                    <h6 class="fw-bold">My Appointments</h6>
                    <p class="text-muted small">View upcoming and past visits</p>
                    <a asp-controller="Appointment" asp-action="Index" class="btn btn-primary btn-sm w-100">
                        View Appointments
                    </a>
                </div>
            </div>
        </div>

        <!-- Medical Records -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-success-soft text-success mb-3">
                        <i class="bi bi-journal-medical fs-2"></i>
                    </div>
                    <h6 class="fw-bold">Medical Records</h6>
                    <p class="text-muted small">Access your health history</p>
                    <a asp-controller="MedicalRecord" asp-action="Index" class="btn btn-success btn-sm w-100">
                        View Records
                    </a>
                </div>
            </div>
        </div>

        <!-- Book Appointment -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-warning-soft text-warning mb-3">
                        <i class="bi bi-calendar-plus fs-2"></i>
                    </div>
                    <h6 class="fw-bold">Book Appointment</h6>
                    <p class="text-muted small">Schedule a doctor visit</p>
                    <a asp-controller="Appointment" asp-action="Book" class="btn btn-warning btn-sm w-100">
                        Book Now
                    </a>
                </div>
            </div>
        </div>

        <!-- Bills -->
        <div class="col-md-6 col-lg-3">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-info-soft text-info mb-3">
                        <i class="bi bi-receipt fs-2"></i>
                    </div>
                    <h6 class="fw-bold">Bills & Payments</h6>
                    <p class="text-muted small">Manage invoices securely</p>
                    <a asp-controller="Patient" asp-action="Bills" class="btn btn-info btn-sm w-100">
                        View Bills
                    </a>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts -->
    <div class="row g-4">

        <!-- Appointments Chart -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-primary mb-3">Appointments Trend</h6>
                    <canvas id="appointmentsChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Payments Chart -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-success mb-3">Payments Trend</h6>
                    <canvas id="paymentsChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Styles -->
<style>
    .dashboard-card {
        transition: all 0.25s ease;
        border-radius: 14px;
    }

    .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .bg-primary-soft { background: rgba(13,110,253,0.1); }
    .bg-success-soft { background: rgba(25,135,84,0.1); }
    .bg-warning-soft { background: rgba(255,193,7,0.15); }
    .bg-info-soft { background: rgba(13,202,240,0.1); }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const appointmentLabels = @Html.Raw(Json.Serialize(ViewBag.AppointmentsDays));
        const appointmentData = @Html.Raw(Json.Serialize(ViewBag.AppointmentsCount));
        const paymentLabels = @Html.Raw(Json.Serialize(ViewBag.RevenueMonths));
        const paymentData = @Html.Raw(Json.Serialize(ViewBag.RevenueValues));

        new Chart(document.getElementById('appointmentsChart'), {
            type: 'line',
            data: {
                labels: appointmentLabels,
                datasets: [{
                    data: appointmentData,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13,110,253,0.1)',
                    tension: 0.4,
                    fill: true,
                    pointRadius: 3
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { grid: { color: '#f1f1f1' } }
                }
            }
        });

        new Chart(document.getElementById('paymentsChart'), {
            type: 'bar',
            data: {
                labels: paymentLabels,
                datasets: [{
                    data: paymentData,
                    backgroundColor: '#20c997'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { grid: { color: '#f1f1f1' } }
                }
            }
        });
    </script>
}