@model ABCClinicSystem.Models.Bill
@{
    ViewData["Title"] = "Edit Bill";
}

<h2>Edit Bill</h2>

<form asp-action="EditBill" method="post">
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <!-- Patient dropdown -->
    <div class="mb-3">
        <label asp-for="PatientId" class="form-label">Patient</label>
        <select asp-for="PatientId" class="form-select" asp-items="ViewBag.Patients"></select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <!-- Doctor dropdown -->
    <div class="mb-3">
        <label asp-for="DoctorId" class="form-label">Doctor</label>
        <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.Doctors"></select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>

    <!-- Amount -->
    <div class="mb-3">
        <label asp-for="Amount" class="form-label">Amount ($)</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <!-- Status dropdown -->
    <div class="mb-3">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select" asp-items="ViewBag.StatusList"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <!-- Description -->
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Bills" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}