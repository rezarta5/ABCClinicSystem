@model IEnumerable<ABCClinicSystem.Models.Bill>
@{
    ViewData["Title"] = "All Bills";
}

<h2 class="mb-4 text-primary">All Bills</h2>

<!-- Display success/error messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Add Bill Button -->
<div class="mb-3">
    <a asp-controller="Admin" asp-action="CreateBill" class="btn btn-success">
        Add New Bill
    </a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Amount ($)</th>
            <th>Paid</th>
            <th>Status</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var bill in Model)
        {
            <tr>
                <td>@(bill.Patient?.FullName ?? "N/A")</td>
                <td>@(bill.Doctor?.FullName ?? "N/A")</td>
                <td>@bill.Amount.ToString("F2")</td>
                <td>
                    @if (bill.Status == "Paid")
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">No</span>
                    }
                </td>
                <td>@bill.Status</td>
                <td>@bill.Description</td>
                <td>
                    <!-- Edit Button -->
                    <a asp-controller="Admin" asp-action="EditBill" asp-route-id="@bill.Id" class="btn btn-sm btn-warning mb-1">Edit</a>

                    <!-- Delete Button -->
                    <form asp-action="DeleteBill" asp-route-id="@bill.Id" method="post" style="display:inline"
                          onsubmit="return confirm('Are you sure you want to delete this bill?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger mb-1">Delete</button>
                    </form>

                    <!-- Update Status Form -->
                    <form asp-controller="Admin" asp-action="UpdateBillStatus" method="post" class="mt-1">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="billId" value="@bill.Id" />

                        <select name="status" class="form-select form-select-sm mb-1">
                            @if (bill.Status == "Pending")
                            {
                                <option value="Pending" selected>Pending</option>
                            }
                            else
                            {
                                <option value="Pending">Pending</option>
                            }

                            @if (bill.Status == "Paid")
                            {
                                <option value="Paid" selected>Paid</option>
                            }
                            else
                            {
                                <option value="Paid">Paid</option>
                            }

                            @if (bill.Status == "Cancelled")
                            {
                                <option value="Cancelled" selected>Cancelled</option>
                            }
                            else
                            {
                                <option value="Cancelled">Cancelled</option>
                            }
                        </select>

                        <button type="submit" class="btn btn-sm btn-primary">Update Status</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>