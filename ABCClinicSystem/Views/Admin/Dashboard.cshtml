@model ABCClinicSystem.Models.Admin
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>

    /* ================= HEADER ================= */
    .card {
        border-radius: 14px;
    }

    .card.mb-5 {
        border: 0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    .card-body.bg-light {
        background: linear-gradient(135deg, #f8fafc, #eef2f7);
    }

    .display-5 {
        letter-spacing: -0.5px;
    }

    /* ================= SUMMARY CARDS ================= */
    .row .card {
        transition: all 0.2s ease;
        border-radius: 14px;
    }

    .row .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.12);
    }

    .row .card h6 {
        font-size: 12px;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        opacity: 0.9;
    }

    .row .display-6 {
        font-weight: 700;
        letter-spacing: -0.5px;
    }

    /* ================= ICONS ================= */
    .card i {
        opacity: 0.85;
    }

    /* ================= QUICK ACTIONS ================= */
    .card.p-3.shadow-sm {
        border-radius: 14px;
        background: #ffffff;
    }

    .card.p-3.shadow-sm h5 {
        font-weight: 600;
        margin-bottom: 12px;
        color: #0f172a;
    }

    .btn {
        border-radius: 10px;
        font-weight: 500;
        padding: 8px 14px;
        transition: all 0.2s ease;
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(0,0,0,0.12);
    }

    /* ================= CHART CARDS ================= */
    canvas {
        padding: 5px;
    }

    .card h6 {
        font-weight: 600;
        color: #0f172a;
    }

    /* ================= BODY BACKGROUND (optional clean look) ================= */
    body {
        background: #f5f7fb;
    }

</style>


<!--  Header -->
    <div class="card mb-5 shadow-sm border-0">
        <div class="card-body bg-light rounded-3 p-4 d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h1 class="display-5 fw-bold text-primary mb-2">Admin Dashboard</h1>
                <p class="lead mb-0">
                    Welcome, <strong>@ViewBag.FullName</strong>
                </p>
            </div>
            <div class="text-end">
                <p class="mb-0 text-muted">
                    <i class="bi bi-calendar3 me-1"></i>
                    @DateTime.Now.ToString("dddd, MMMM dd yyyy")
                </p>
            </div>
        </div>
    </div>
    

<!-- ======================== Summary Cards ======================== -->
<div class="row row-cols-1 row-cols-md-2 row-cols-xl-6 g-3 mb-4">
    <div class="col">
        <div class="card border-0 shadow-sm h-100 text-white bg-info">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6>Total Users</h6>
                    <p class="display-6 mb-0">@Model.TotalUsers</p>
                </div>
                <i class="bi bi-people-fill display-4"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 text-white bg-success">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6>Total Doctors</h6>
                    <p class="display-6 mb-0">@Model.TotalDoctors</p>
                </div>
                <i class="bi bi-person-badge-fill display-4"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 text-dark bg-warning">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6>Total Patients</h6>
                    <p class="display-6 mb-0">@Model.TotalPatients</p>
                </div>
                <i class="bi bi-heart-fill display-4"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 text-white bg-danger">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6>Total Appointments</h6>
                    <p class="display-6 mb-0">@Model.TotalAppointments</p>
                </div>
                <i class="bi bi-calendar-check-fill display-4"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 text-white bg-secondary">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6>Total Bills</h6>
                    <p class="display-6 mb-0">@Model.TotalBills</p>
                </div>
                <i class="bi bi-receipt display-4"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 text-white bg-primary">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6>Total Revenue</h6>
                    <p class="display-6 mb-0">$@Model.TotalRevenue.ToString("N2")</p>
                </div>
                <i class="bi bi-currency-dollar display-4"></i>
            </div>
        </div>
    </div>
</div>

<!-- ======================== Quick Action Buttons ======================== -->
<div class="card p-3 shadow-sm mt-4">
    <h5 class="mb-3">Quick Actions</h5>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="ApplicationUser" asp-action="Index" class="btn btn-primary shadow-sm">
            <i class="bi bi-people"></i> Users / Staff
        </a>
        <a asp-controller="Appointment" asp-action="Index" class="btn btn-success shadow-sm">
            <i class="bi bi-calendar-check"></i> Appointments
        </a>
        <a asp-controller="MedicalRecord" asp-action="Index" class="btn btn-warning shadow-sm text-dark">
            <i class="bi bi-journal-medical"></i> Medical Records
        </a>
        <a asp-controller="Admin" asp-action="Bills" class="btn btn-secondary shadow-sm">
            <i class="bi bi-receipt"></i> Bills
        </a>
        <a asp-controller="Admin" asp-action="Departments" class="btn btn-info shadow-sm text-dark">
            <i class="bi bi-building"></i> Departments & Services
        </a>
    </div>
</div>

<!-- ======================== Charts ======================== -->
<div class="row mt-4 g-3">
    <div class="col-md-6">
        <div class="card p-3 shadow-sm h-100">
            <h6>Revenue Trends</h6>
            <canvas id="revenueChart"></canvas>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-3 shadow-sm h-100">
            <h6>Appointments by Department</h6>
            <canvas id="appointmentsChart"></canvas>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Revenue Chart
    var revenueCtx = document.getElementById('revenueChart').getContext('2d');
    var revenueChart = new Chart(revenueCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.Months)),
            datasets: [{
                label: 'Revenue',
                data: @Html.Raw(Json.Serialize(ViewBag.Revenue)),
                borderColor: 'rgba(75, 192, 192, 1)',
                backgroundColor: 'rgba(75, 192, 192, 0.2)',
                fill: true
            }]
        }
    });

    // Appointments by Department
    var apptCtx = document.getElementById('appointmentsChart').getContext('2d');
    var apptChart = new Chart(apptCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.Departments)),
            datasets: [{
                label: 'Appointments',
                data: @Html.Raw(Json.Serialize(ViewBag.AppointmentsByDept)),
                backgroundColor: 'rgba(54, 162, 235, 0.7)'
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } }
        }
    });
</script>
