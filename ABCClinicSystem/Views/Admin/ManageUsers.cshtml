@model List<ABCClinicSystem.Models.ApplicationUser>

@{
    ViewData["Title"] = "Manage Users";
}

<h1 class="text-primary">Manage Users</h1>

<table class="table table-striped mt-3">
    <thead>
    <tr>
        <th>Email</th>
        <th>Full Name</th>
        <th>Roles</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Email</td>
            <td>@user.FullName</td>
            <td>
                @* Display all roles assigned to this user *@
                @if (user.RoleType != null)
                {
                    @user.RoleType
                }
                else
                {
                    <span class="text-muted">No Role</span>
                }
            </td>
            <td>
                <a class="btn btn-sm btn-primary me-1" asp-action="EditUser" asp-route-id="@user.Id">Edit</a>

                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" 
                      onsubmit="return confirm('Are you sure you want to delete this user?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>