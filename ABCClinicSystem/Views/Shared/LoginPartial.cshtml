@using ABCClinicSystem.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-dark">Hello @User.FindFirst("FullName")?.Value ?? "Guest"!</a>
        </li>

        @* Role dashboards *@
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
            </li>
        }
        else if (User.IsInRole("Doctor"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Doctor" asp-action="Dashboard">Doctor Dashboard</a>
            </li>
        }
        else if (User.IsInRole("Manager"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Manager" asp-action="Dashboard">Manager Dashboard</a>
            </li>
        }
        else if (User.IsInRole("Patient"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Patient" asp-action="Dashboard">My Dashboard</a>
            </li>
        }

        <li class="nav-item">
            <form method="post" asp-area="Identity" asp-page="/Account/Logout">
                <button type="submit" class="btn btn-link nav-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
    }
</ul>