@{
    ViewData["Title"] = "Privacy & Cookies Policy";
}

<div class="container my-5">
    <h1 class="mb-4 text-primary">Privacy & Cookies Policy</h1>
    <p class="lead">Effective Date: April 2, 2026</p>

    <h4>1. Information We Collect</h4>
    <p>We collect personal info (name, email, medical data) and non-personal info (IP, device info) to provide care and improve our services.</p>

    <h4>2. How We Use Your Information</h4>
    <ul>
        <li>Provide medical care and services</li>
        <li>Manage appointments, records, and billing</li>
        <li>Send important updates</li>
        <li>Improve website and security</li>
        <li>Comply with legal obligations</li>
    </ul>

    <h4>3. Cookies & Tracking</h4>
    <p>We use cookies to maintain sessions, improve functionality, and analyze website usage. You can accept or reject cookies via the banner.</p>

    <h4>4. Sharing Your Information</h4>
    <p>We share information only with authorized staff, service providers, or when required by law.</p>

    <h4>5. Security</h4>
    <p>We use encryption, secure login, and access control to protect your data.</p>

    <h4>6. Your Rights</h4>
    <p>You can access, correct, or request deletion of your data. Contact: <a href="mailto:privacy@abcclinic.com">privacy@abcclinic.com</a></p>

    <h4>7. Additional Information</h4>
    <p>Records are retained at least 7 years. Services are not for children under 13. Changes will be posted with an updated date. Contact: +1 (555) 123-4567</p>

    <div class="alert alert-info mt-4">
        This website uses cookies to ensure you get the best experience. 
        <a href="@Url.Action("Privacy", "Home")" class="text-primary text-decoration-underline">Learn more</a>
    </div>
</div>