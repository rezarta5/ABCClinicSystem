@model ABCClinicSystem.Models.Appointment

@{
    ViewData["Title"] = "Edit Appointment";
}

<h1 class="text-warning">Edit Appointment</h1>

@if (TempData["Errors"] != null)
{
    <div class="alert alert-danger">@TempData["Errors"]</div>
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
    {
        <!-- DOCTOR / ADMIN FULL EDIT -->

        <div class="mb-3">
            <label asp-for="DoctorId" class="form-label"></label>
            <select asp-for="DoctorId"
                    asp-items="Model.Doctors ?? new List<SelectListItem>()"
                    class="form-select">
                <option value="">-- Select Doctor --</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="PatientId" class="form-label"></label>
            <select asp-for="PatientId"
                    asp-items="Model.Patients ?? new List<SelectListItem>()"
                    class="form-select">
                <option value="">-- Select Patient --</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="DepartmentId" class="form-label"></label>
            <select asp-for="DepartmentId"
                    asp-items="Model.Departments ?? new List<SelectListItem>()"
                    class="form-select">
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="ServiceId" class="form-label"></label>
            <select asp-for="ServiceId"
                    asp-items="Model.Services ?? new List<SelectListItem>()"
                    class="form-select">
                <option value="">-- Select Service --</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="AppointmentDate" class="form-label"></label>
            <input asp-for="AppointmentDate"
                   type="datetime-local"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="AppointmentType" class="form-label"></label>
            <select asp-for="AppointmentType"
                    asp-items="Model.AppointmentTypes ?? new List<SelectListItem>()"
                    class="form-select">
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Reason" class="form-label"></label>
            <textarea asp-for="Reason" class="form-control"></textarea>
        </div>
    }

    else if (User.IsInRole("Patient"))
    {
        <!-- PATIENT LIMITED EDIT -->

        <div class="mb-3">
            <label>Doctor</label>
            <input class="form-control"
                   value="@(Model.Doctor?.FullName ?? "N/A")"
                   disabled />
            <input type="hidden" asp-for="DoctorId" />
        </div>

        <div class="mb-3">
            <label>Patient</label>
            <input class="form-control"
                   value="@(Model.Patient?.FullName ?? "N/A")"
                   disabled />
            <input type="hidden" asp-for="PatientId" />
        </div>

        <div class="mb-3">
            <label>Department</label>
            <input class="form-control"
                   value="@(Model.Department?.Name ?? "N/A")"
                   disabled />
            <input type="hidden" asp-for="DepartmentId" />
        </div>

        <div class="mb-3">
            <label>Service</label>
            <input class="form-control"
                   value="@(Model.Service?.Name ?? "N/A")"
                   disabled />
            <input type="hidden" asp-for="ServiceId" />
        </div>

        <div class="mb-3">
            <label asp-for="AppointmentDate" class="form-label"></label>
            <input asp-for="AppointmentDate"
                   type="datetime-local"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Reason" class="form-label"></label>
            <textarea asp-for="Reason" class="form-control"></textarea>
        </div>
    }

    <br />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-warning">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(function () {

            function loadServices(departmentId, selectedServiceId) {

                var serviceDropdown = $('#ServiceId');
                serviceDropdown.empty();
                serviceDropdown.append('<option value="">-- Select Service --</option>');

                if (!departmentId) return;

                $.getJSON('@Url.Action("GetServicesByDepartment", "Appointment")',
                    { departmentId: departmentId },
                    function (data) {

                        $.each(data, function (i, service) {

                            var selected = selectedServiceId == service.id ? "selected" : "";

                            serviceDropdown.append(
                                `<option value="${service.id}" ${selected}>${service.name}</option>`
                            );
                        });
                    });
            }

            var selectedDept = $('#DepartmentId').val();
            var selectedService = '@Model.ServiceId';

            if (selectedDept) {
                loadServices(selectedDept, selectedService);
            }

            $('#DepartmentId').change(function () {
                loadServices($(this).val(), null);
            });

        });
    </script>
}