@model List<ABCClinicSystem.Models.ApplicationUser>

@{
    ViewData["Title"] = "Manage Users";
}

<h1 class="text-primary">Manage Users</h1>

<!-- Success message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped mt-3">
    <thead>
    <tr>
        <th>Email</th>
        <th>Full Name</th>
        <th>Role</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Email</td>
            <td>@user.FullName</td>
            <td>@(user.RoleType ?? "No Role")</td>
            <td>
                <a class="btn btn-sm btn-primary me-1" asp-action="Edit" asp-route-id="@user.Id">Edit</a>

                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Are you sure you want to delete this user?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-success mt-3">Add New User</a>