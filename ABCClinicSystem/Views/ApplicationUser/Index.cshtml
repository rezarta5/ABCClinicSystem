@model IEnumerable<ABCClinicSystem.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users";
}

<h2>Users</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Add New User</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
    <tr>
        <th>Full Name</th>
        <th>Username</th>
        <th>Email</th>
        <th>Role</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.FullName</td>
            <td>@user.UserName</td>
            <td>@user.Email</td>
            <td>@user.RoleType</td>
            <td>
                <a class="btn btn-sm btn-info" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@user.Id"
                   onclick="return confirm('Are you sure you want to delete this user?');">
                    Delete
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>